{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>SonarSource/renovate-config"
  ],
  "enabledManagers": [
    "github-actions",
    "gradle",
    "cargo",
    "npm",
    "mise"
  ],
  "ignorePaths": [
    "e2e/src/test/resources/**"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gradle"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all Gradle non-major dependencies",
      "groupSlug": "all-gradle-minor-patch"
    },
    {
      "matchManagers": [
        "cargo"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all Rust non-major dependencies",
      "groupSlug": "all-rust-minor-patch"
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "all npm non-major dependencies",
      "groupSlug": "all-npm-minor-patch"
    },
    {
      "matchManagers": [
        "cargo",
        "npm"
      ],
      "matchPackageNames": [
        "tree-sitter",
        "tree-sitter-rust"
      ],
      "groupName": "all tree-sitter dependencies",
      "groupSlug": "all-tree-sitter",
      "separateMajorMinor": false,
      "separateMinorPatch": false
    },
    {
      "matchManagers": [
        "mise"
      ],
      "matchDepNames": [
        "java"
      ],
      "allowedVersions": "/^21(\\.|$)/"
    },
    {
      "matchPackageNames": [
        "/sonar-plugin-api/",
        "/org.sonarsource.sonarqube.*/"
      ],
      "groupName": "sonarqube",
      "groupSlug": "sq"
    },
    {
      "matchPackageNames": [
        "org.sonarsource.parent:parent",
        "com.sonarsource.parent:parent"
      ],
      "groupName": "parent",
      "groupSlug": "parent"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "rollbackPrs": false,
      "matchPackageNames": [
        "SonarSource/*",
        "sonarsource/*"
      ],
      "pinDigests": false,
      "groupName": "all Sonar GitHub Actions",
      "groupSlug": "all-sonar-github-actions"
    },
    {
      "description": "SonarSource GitHub actions do not need version pinning",
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "SonarSource/*",
        "sonarsource/*"
      ],
      "matchUpdateTypes": [
        "pin",
        "rollback"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "rollbackPrs": false,
      "matchPackageNames": [
        "!SonarSource/*",
        "!sonarsource/*"
      ],
      "groupName": "all third-party GitHub Actions",
      "groupSlug": "all-3rd-party-github-actions"
    }
  ]
}
